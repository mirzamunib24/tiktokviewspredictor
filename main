        <h1 class="text-3xl font-extrabold tracking-tight mb-2">
            TikTok <span class="text-[#ff0050]">View</span> <span class="text-[#00f2ea]">Predictor</span>
        </h1>
        <p class="text-gray-400 text-sm italic">Analyze your reach before you post</p>
    </header>

    <!-- Main Tool -->
    <main class="w-full max-w-md space-y-6">
        
        <!-- Input Form -->
        <div id="input-section" class="glass-card rounded-3xl p-6 space-y-5">
            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2 ml-1">Channel Name</label>
                <input type="text" id="channelName" placeholder="@username" 
                    class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-white placeholder-gray-600 focus:outline-none focus:border-[#00f2ea] transition-all">
            </div>

            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2 ml-1">Video Title / Poetry</label>
                <textarea id="videoText" placeholder="Write your hook or poetry here..." rows="3"
                    class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-white placeholder-gray-600 focus:outline-none focus:border-[#ff0050] transition-all resize-none"></textarea>
            </div>

            <div>
                <label class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2 ml-1">Category</label>
                <div class="grid grid-cols-3 gap-2">
                    <button onclick="setCategory('Poetry')" class="cat-btn py-3 rounded-xl bg-white/5 border border-white/10 text-xs font-bold transition-all hover:bg-white/10">Poetry</button>
                    <button onclick="setCategory('Lipsync')" class="cat-btn py-3 rounded-xl bg-white/5 border border-white/10 text-xs font-bold transition-all hover:bg-white/10">Lipsync</button>
                    <button onclick="setCategory('Editing')" class="cat-btn py-3 rounded-xl bg-white/5 border border-white/10 text-xs font-bold transition-all hover:bg-white/10">Editing</button>
                </div>
            </div>

            <button onclick="generatePrediction()" id="predictBtn" 
                class="predict-btn w-full py-5 rounded-2xl tiktok-gradient text-black font-extrabold text-lg uppercase tracking-widest shadow-xl mt-4">
                Predict Reach
            </button>
        </div>

        <!-- Result Section (Hidden initially) -->
        <div id="result-section" class="hidden glass-card rounded-3xl p-8 text-center space-y-6 border-[#00f2ea]/30">
            <div>
                <h2 class="text-gray-400 text-sm font-bold uppercase tracking-widest mb-2">Estimated Views</h2>
                <div id="viewRange" class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">
                    --
                </div>
            </div>

            <div class="h-px bg-white/10 w-full"></div>

            <div>
                <h2 class="text-[#00f2ea] text-xs font-bold uppercase tracking-widest mb-3">Tone Analysis</h2>
                <p id="toneLabel" class="text-lg font-medium text-white italic">"Highly Engaging"</p>
            </div>

            <div class="bg-white/5 rounded-2xl p-5 border border-white/5">
                <span class="block text-[#ff0050] text-[10px] font-bold uppercase mb-1">Creator Pro Tip</span>
                <p id="proTip" class="text-sm text-gray-300 leading-relaxed"></p>
            </div>

            <button onclick="resetTool()" class="text-gray-500 text-xs font-bold uppercase tracking-widest hover:text-white transition-colors">
                Try Another Video
            </button>
        </div>

