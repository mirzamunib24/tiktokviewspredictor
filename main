    <!-- Custom Modal/Message Box -->
    <div id="messageBox" class="fixed inset-0 bg-black/80 flex items-center justify-center p-6 z-50 hidden">
        <div class="bg-[#111] border border-white/10 rounded-3xl p-8 max-w-xs w-full text-center">
            <p id="messageText" class="mb-6 text-gray-300"></p>
            <button onclick="closeMessage()" class="w-full py-3 bg-white text-black font-bold rounded-xl">Got it</button>
        </div>
    </div>

    <script>
        let selectedCategory = '';

        function setCategory(cat) {
            selectedCategory = cat;
            document.querySelectorAll('.cat-btn').forEach(btn => {
                btn.classList.remove('border-[#00f2ea]', 'bg-[#00f2ea]/10', 'text-[#00f2ea]');
                if (btn.innerText === cat) {
                    btn.classList.add('border-[#00f2ea]', 'bg-[#00f2ea]/10', 'text-[#00f2ea]');
                }
            });
        }

        function showMessage(text) {
            document.getElementById('messageText').innerText = text;
            document.getElementById('messageBox').classList.remove('hidden');
        }

        function closeMessage() {
            document.getElementById('messageBox').classList.add('hidden');
        }

        function analyzeTone(text) {
            const emotionalWords = ['love', 'sad', 'heart', 'deep', 'pain', 'happy', 'fire', 'wow', 'crazy', 'alone', 'broken'];
            const strongWords = ['must', 'stop', 'secret', 'never', 'always', 'everyone'];
            
            let score = 0;
            const lowerText = text.toLowerCase();
            
            emotionalWords.forEach(word => { if(lowerText.includes(word)) score += 2; });
            strongWords.forEach(word => { if(lowerText.includes(word)) score += 3; });
            
            if (text.length > 50) score += 2;
            if (text.includes('?')) score += 1;
            if (text.includes('!')) score += 2;

            if (score > 10) return { label: "Viral Potential", boost: 1.5 };
            if (score > 5) return { label: "High Resonance", boost: 1.2 };
            return { label: "Steady Reach", boost: 1.0 };
        }

        const tips = [
            "Use a trending 'Low-Fi' sound to keep the focus on your text.",
            "Try adding high-contrast captions to improve watch time.",
            "The first 2 seconds are critical. Add a visual movement immediately.",
            "Film in front of a window for natural, flattering lighting.",
            "Reply to the first 5 comments to boost algorithm visibility.",
            "Use 3-5 relevant hashtags like #fyp and specific niche tags.",
            "Post between 6:00 PM and 9:00 PM for peak local engagement."
        ];

        function generatePrediction() {
            const channel = document.getElementById('channelName').value;
            const text = document.getElementById('videoText').value;

            if (!channel || !text || !selectedCategory) {
                showMessage("Please fill in all fields and pick a category!");
                return;
            }

            const btn = document.getElementById('predictBtn');
            btn.innerText = "Analyzing...";
            btn.disabled = true;

            // Fake loading for effect
            setTimeout(() => {
                const analysis = analyzeTone(text);
                
                // Mock Logic for Ranges
                let baseMin = 500;
                let baseMax = 2500;

                if (selectedCategory === 'Poetry') { baseMin = 800; baseMax = 4000; }
                if (selectedCategory === 'Editing') { baseMin = 1200; baseMax = 8000; }
                if (selectedCategory === 'Lipsync') { baseMin = 300; baseMax = 1500; }

                const finalMin = Math.floor(baseMin * analysis.boost);
                const finalMax = Math.floor(baseMax * analysis.boost);

                // Update UI
                document.getElementById('viewRange').innerText = `${(finalMin/1000).toFixed(1)}k - ${(finalMax/1000).toFixed(1)}k`;
                document.getElementById('toneLabel').innerText = `"${analysis.label}"`;
                document.getElementById('proTip').innerText = tips[Math.floor(Math.random() * tips.length)];

                // Switch Panels
                document.getElementById('input-section').classList.add('hidden');
                document.getElementById('result-section').classList.remove('hidden');
                
                btn.innerText = "Predict Reach";
                btn.disabled = false;
                
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }, 1200);
        }

        function resetTool() {
            document.getElementById('input-section').classList.remove('hidden');
            document.getElementById('result-section').classList.add('hidden');
            document.getElementById('videoText').value = '';
            setCategory('');
        }
    </script>
</body>
